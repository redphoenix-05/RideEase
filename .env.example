# Example environment variables for RideEase
# Copy this file to `.env` and replace placeholders with real values.

# Database
DB_URL=jdbc:mysql://localhost:3306/rideease-1
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Google Maps API
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Payment gateway (sandbox defaults shown)
TRANSACTION_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
STORE_ID=your_store_id
STORE_PASSWORD=your_store_password

# Payment callback URLs
PAYMENT_SUCCESS_URL=http://127.0.0.1:1000/success_done
PAYMENT_FAIL_URL=http://127.0.0.1:1000/faildone
PAYMENT_CANCEL_URL=http://127.0.0.1:1000/canceldone
