<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="471.0" prefWidth="803.0" style="-fx-background-color: linear-gradient(to bottom right, #0b1120, #1e3a5f);" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.rideease.DashboardController">
    <children>
        <ImageView fitHeight="471.0" fitWidth="803.0" mouseTransparent="true" preserveRatio="false" smooth="true">
            <image>
                <Image url="@/com/example/rideease/assets/picture1.jpg" />
            </image>
        </ImageView>
        <Label layoutX="23.0" layoutY="40.0" prefHeight="27.0" prefWidth="203.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="Welcome to RideEase">
            <font>
                <Font name="Comic Sans MS" size="12.0" />
            </font>
        </Label>

        <!-- Dropdown Menu Button -->
        <MenuButton fx:id="userMenuButton" layoutX="696.0" layoutY="39.0" style="-fx-font-size: 14px; -fx-background-color: rgba(255, 255, 255, 0.7);" text="User ▼">
            <items>
                <MenuItem onAction="#handleMyProfile" text="My Profile" />
                <MenuItem onAction="#handleMyScheduledRide" text="My Scheduled Ride" />
                <MenuItem onAction="#handleLogout" text="Logout" />
            </items>
        </MenuButton>

        <!-- Vehicle Selection -->
        <Label layoutX="21.0" layoutY="93.0" style="-fx-font-size: 16px; -fx-text-fill: white;" text="Choose the type of vehicle for your journey :" />

        <!-- Radio Buttons for Vehicle Selection -->
        <RadioButton fx:id="bikeRadioButton" layoutX="21.0" layoutY="136.0" style="-fx-text-fill: white;" text="Bike" />
        <RadioButton fx:id="carRadioButton" layoutX="23.0" layoutY="168.0" style="-fx-text-fill: white;" text="Car" />

        <!-- Buttons -->
        <Button fx:id="scheduleRideButton" layoutX="21.0" layoutY="221.0" onAction="#handleScheduleRide" style="-fx-font-size: 14px; -fx-background-color: rgba(0, 0, 0, 0.6); -fx-text-fill: white;" text="Schedule Your Ride" />
        <Button fx:id="bookRideNowButton" layoutX="178.0" layoutY="221.0" onAction="#handleBookRideNow" style="-fx-font-size: 14px; -fx-background-color: rgba(0, 0, 0, 0.6); -fx-text-fill: white;" text="Book Your Ride Now" />
    </children>
</AnchorPane>
