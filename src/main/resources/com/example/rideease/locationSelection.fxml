<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.web.WebView?>

<AnchorPane prefHeight="609.0" prefWidth="1130.0" style="-fx-background-color: linear-gradient(to bottom right, #0b1120, #0f172a);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.rideease.LocationSelectionController">
    <WebView fx:id="mapView" layoutX="21.0" layoutY="52.0" prefHeight="542.0" prefWidth="846.0" />

    <Label layoutX="873.0" layoutY="209.0" text="Start Location:" />
    <TextField fx:id="startLocationTextField" layoutX="971.0" layoutY="205.0" promptText="Enter Start Location" />

    <Label layoutX="875.0" layoutY="268.0" text="End Location:" />
    <TextField fx:id="endLocationTextField" layoutX="971.0" layoutY="264.0" promptText="Enter End Location" />

    <!-- Fare Text initially hidden -->
    <Text fx:id="fareText" layoutX="878.0" layoutY="384.0" style="-fx-font-size: 18;" text="Fare: - Taka" visible="false" />

    <!-- Proceed to Checkout Button initially hidden -->
    <Button fx:id="confirmButton" layoutX="952.0" layoutY="415.0" onAction="#handleProceedToCheckout" text="Proceed To Checkout" visible="false" />

    <Button layoutX="987.0" layoutY="310.0" mnemonicParsing="false" onAction="#handleOnMap" text="Confirm" />

    <Button layoutX="21.0" layoutY="14.0" mnemonicParsing="false" onAction="#handlebackbutton" text="&lt;--" />

    <Label fx:id="dateLabel" layoutX="873.0" layoutY="65.0" text="Date of Journey:" visible="false" />
    <TextField fx:id="dateTextField" layoutX="966.0" layoutY="61.0" promptText="Enter Date" visible="false" />

    <!-- Time TextField (HH:mm format) -->
    <Label fx:id="timeLabel" layoutX="875.0" layoutY="101.0" text="Time:" visible="false" />
    <TextField fx:id="timeTextField" layoutX="924.0" layoutY="96.0" prefHeight="26.0" prefWidth="91.0" promptText="HH:mm" visible="false" />
</AnchorPane>
