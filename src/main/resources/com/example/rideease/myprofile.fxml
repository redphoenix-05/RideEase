<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="499.0" prefWidth="819.0" style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #111827);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.rideease.MyProfileController">
    <children>
        <!-- Profile Text -->
        <Text layoutX="46.0" layoutY="134.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Name :" wrappingWidth="55.982025146484375" />
        <Text fx:id="nameText" layoutX="111.0" layoutY="134.0" strokeType="OUTSIDE" strokeWidth="0.0" text="-" wrappingWidth="200.0" />

        <Text layoutX="46.0" layoutY="170.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Email :" wrappingWidth="55.982025146484375" />
        <Text fx:id="emailText" layoutX="111.0" layoutY="170.0" strokeType="OUTSIDE" strokeWidth="0.0" text="-" wrappingWidth="200.0" />

        <Text layoutX="46.0" layoutY="209.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Phone :" wrappingWidth="55.982025146484375" />
        <Text fx:id="phoneText" layoutX="111.0" layoutY="209.0" strokeType="OUTSIDE" strokeWidth="0.0" text="-" wrappingWidth="200.0" />

        <Text layoutX="46.0" layoutY="246.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Gender :" wrappingWidth="55.982025146484375" />
        <Text fx:id="genderText" layoutX="111.0" layoutY="246.0" strokeType="OUTSIDE" strokeWidth="0.0" text="-" wrappingWidth="200.0" />

        <!-- Back Button -->
        <Button fx:id="backButton" layoutX="29.0" layoutY="23.0" mnemonicParsing="false" onAction="#handleBackButtonClick" text="&lt;--" />

        <!-- Log Out Button -->
        <Button fx:id="logoutButton" layoutX="147.0" layoutY="345.0" mnemonicParsing="false" onAction="#handleLogoutButtonClick" text="Log Out" />

        <!-- Update Profile Button -->
        <Button fx:id="updateProfileButton" layoutX="257.0" layoutY="286.0" mnemonicParsing="false" onAction="#handleUpdateProfileButtonClick" text="Update Profile" />

        <!-- Update Profile Text -->
        <Text disable="true" layoutX="46.0" layoutY="303.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Do you want to update your profile?" wrappingWidth="201.7698974609375" />
      <ImageView fitHeight="499.0" fitWidth="453.0" layoutX="367.0" preserveRatio="true" smooth="true">
         <image>
            <Image url="@/com/example/rideease/assets/wallpaperflare.com_wallpaper12.JPG" />
         </image>
      </ImageView>
    </children>
</AnchorPane>
