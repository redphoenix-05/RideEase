<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: linear-gradient(to bottom right, #111827, #1f2937);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.rideease.UpdateProfileController">
    <children>
        <Label layoutX="200.0" layoutY="20.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Update Profile" />

        <Label layoutX="50.0" layoutY="80.0" text="Name:" />
        <TextField fx:id="nameTextField" layoutX="150.0" layoutY="75.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="130.0" text="Phone:" />
        <TextField fx:id="phoneTextField" layoutX="150.0" layoutY="125.0" prefWidth="300.0" />

        <Label layoutX="50.0" layoutY="180.0" text="Email:" />
        <TextField fx:id="emailTextField" layoutX="150.0" layoutY="175.0" prefWidth="300.0" />

        <Button layoutX="150.0" layoutY="250.0" mnemonicParsing="false" text="Save Changes" onAction="#handleSaveChanges" />
        <Button layoutX="300.0" layoutY="250.0" mnemonicParsing="false" text="Back" onAction="#handleBackButton" />

        <Text fx:id="errorText" layoutX="150.0" layoutY="300.0" fill="red" visible="false" />
    </children>
</AnchorPane>
